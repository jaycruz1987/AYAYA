generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone           String?          @unique @db.VarChar(20)
  email           String?          @unique @db.VarChar(100)
  password_hash   String?          @db.VarChar(255)
  nickname        String?          @db.VarChar(50)
  avatar_url      String?          @db.VarChar(255)
  status          String?          @default("ACTIVE") @db.VarChar(20)
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  orders          Order[]
  serviceRequests ServiceRequest[]
  addresses       UserAddress[]

  @@map("users")
}

model AdminUser {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String               @db.VarChar(50)
  email               String               @unique @db.VarChar(100)
  phone               String?              @unique @db.VarChar(20)
  password_hash       String               @db.VarChar(255)
  role                String               @default("ADMIN") @db.VarChar(50)
  status              String?              @default("ACTIVE") @db.VarChar(20)
  createdAt           DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?            @default(now()) @map("updated_at") @db.Timestamptz(6)
  partnerApplications PartnerApplication[]
  serviceRequests     ServiceRequest[]

  @@map("admin_users")
}

model UserAddress {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  label        String?   @db.VarChar(50)
  contactName  String    @map("contact_name") @db.VarChar(50)
  contactPhone String    @map("contact_phone") @db.VarChar(20)
  addressLine  String    @map("address_line") @db.VarChar(255)
  city         String    @db.VarChar(100)
  township     String?   @db.VarChar(100)
  landmark     String?   @db.VarChar(255)
  buildingName String?   @map("building_name") @db.VarChar(255)
  floor        String?   @db.VarChar(20)
  roomNo       String?   @map("room_no") @db.VarChar(50)
  latitude     Decimal?  @db.Decimal(10, 7)
  longitude    Decimal?  @db.Decimal(10, 7)
  isDefault    Boolean?  @default(false) @map("is_default")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_addresses")
}

model MerchantCategory {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String     @db.VarChar(50)
  sortOrder Int?       @default(0) @map("sort_order")
  isActive  Boolean?   @default(true) @map("is_active")
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?  @map("deleted_at") @db.Timestamptz(6)
  merchants Merchant[]

  @@map("merchant_categories")
}

model Merchant {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId         String?           @map("category_id") @db.Uuid
  name               String            @db.VarChar(100)
  description        String?
  logoUrl            String?           @map("logo_url") @db.VarChar(255)
  coverImageUrl      String?           @map("cover_image_url") @db.VarChar(255)
  contactName        String?           @map("contact_name") @db.VarChar(50)
  contactPhone       String?           @map("contact_phone") @db.VarChar(20)
  addressLine        String?           @map("address_line") @db.VarChar(255)
  city               String?           @db.VarChar(100)
  township           String?           @db.VarChar(100)
  landmark           String?           @db.VarChar(255)
  buildingName       String?           @map("building_name") @db.VarChar(255)
  latitude           Decimal?          @db.Decimal(10, 7)
  longitude          Decimal?          @db.Decimal(10, 7)
  serviceMode        String?           @default("DELIVERY") @map("service_mode") @db.VarChar(20)
  minimumOrderAmount Decimal?          @default(0.00) @map("minimum_order_amount") @db.Decimal(10, 2)
  deliveryRadiusKm   Decimal?          @map("delivery_radius_km") @db.Decimal(5, 2)
  operatingStatus    String?           @default("OPEN") @map("operating_status") @db.VarChar(20)
  isFeatured         Boolean?          @default(false) @map("is_featured")
  status             String?           @default("ACTIVE") @db.VarChar(20)
  createdAt          DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime?         @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?         @map("deleted_at") @db.Timestamptz(6)
  category           MerchantCategory? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders             Order[]
  productCategories  ProductCategory[]
  products           Product[]
  users              MerchantUser[]

  @@map("merchants")
}

model ProductCategory {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId String    @map("merchant_id") @db.Uuid
  name       String    @db.VarChar(50)
  sortOrder  Int?      @default(0) @map("sort_order")
  status     String?   @default("ACTIVE") @db.VarChar(20)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products   Product[]

  @@map("product_categories")
}

model Product {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId  String          @map("merchant_id") @db.Uuid
  categoryId  String          @map("category_id") @db.Uuid
  name        String          @db.VarChar(100)
  description String?
  imageUrl    String?         @map("image_url") @db.VarChar(255)
  price       Decimal         @db.Decimal(10, 2)
  stock       Int?            @default(-1)
  status      String?         @default("ON_SHELF") @db.VarChar(20)
  createdAt   DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?       @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?       @map("deleted_at") @db.Timestamptz(6)
  orderItems  OrderItem[]
  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  merchant    Merchant        @relation(fields: [merchantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("products")
}

model Hotel {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String           @db.VarChar(100)
  starRating      Int?             @map("star_rating")
  description     String?
  coverImageUrl   String?          @map("cover_image_url") @db.VarChar(255)
  contactName     String?          @map("contact_name") @db.VarChar(50)
  contactPhone    String?          @map("contact_phone") @db.VarChar(20)
  addressLine     String           @map("address_line") @db.VarChar(255)
  city            String           @db.VarChar(100)
  township        String?          @db.VarChar(100)
  landmark        String?          @db.VarChar(255)
  buildingName    String?          @map("building_name") @db.VarChar(255)
  latitude        Decimal?         @db.Decimal(10, 7)
  longitude       Decimal?         @db.Decimal(10, 7)
  checkInTime     String?          @map("check_in_time") @db.VarChar(10)
  checkOutTime    String?          @map("check_out_time") @db.VarChar(10)
  facilities      Json?
  isFeatured      Boolean?         @default(false) @map("is_featured")
  status          String?          @default("ACTIVE") @db.VarChar(20)
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  roomTypes       RoomType[]
  serviceRequests ServiceRequest[]
  users           HotelUser[]

  @@map("hotels")
}

model RoomType {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId         String           @map("hotel_id") @db.Uuid
  name            String           @db.VarChar(100)
  description     String?
  coverImageUrl   String?          @map("cover_image_url") @db.VarChar(255)
  imageUrls       Json?            @map("image_urls")
  bedType         String?          @map("bed_type") @db.VarChar(50)
  roomSizeSqm     Int?             @map("room_size_sqm")
  maxOccupancy    Int?             @default(2) @map("max_occupancy")
  basePrice       Decimal          @map("base_price") @db.Decimal(10, 2)
  sortOrder       Int?             @default(0) @map("sort_order")
  status          String?          @default("ACTIVE") @db.VarChar(20)
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  hotel           Hotel            @relation(fields: [hotelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  serviceRequests ServiceRequest[]

  @@map("room_types")
}

model Order {
  id                      String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNo                 String      @unique @map("order_no") @db.VarChar(50)
  userId                  String      @map("user_id") @db.Uuid
  merchantId              String      @map("merchant_id") @db.Uuid
  orderType               String      @default("DELIVERY") @map("order_type") @db.VarChar(20)
  totalAmount             Decimal     @map("total_amount") @db.Decimal(10, 2)
  orderStatus             String?     @default("PENDING") @map("order_status") @db.VarChar(20)
  paymentStatus           String?     @default("UNPAID") @map("payment_status") @db.VarChar(20)
  fulfillmentStatus       String?     @default("PENDING") @map("fulfillment_status") @db.VarChar(20)
  paymentMethod           String?     @map("payment_method") @db.VarChar(50)
  deliveryAddressSnapshot Json?       @map("delivery_address_snapshot")
  remarks                 String?
  createdAt               DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime?   @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt               DateTime?   @map("deleted_at") @db.Timestamptz(6)
  orderItems              OrderItem[]
  merchant                Merchant    @relation(fields: [merchantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                    User        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("orders")
}

model OrderItem {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String    @map("order_id") @db.Uuid
  productId   String?   @map("product_id") @db.Uuid
  productName String    @map("product_name") @db.VarChar(100)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(10, 2)
  quantity    Int
  totalPrice  Decimal   @map("total_price") @db.Decimal(10, 2)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product     Product?  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("order_items")
}

model PartnerApplication {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNo         String     @unique @map("reference_no") @db.VarChar(50)
  type                String     @db.VarChar(30)
  requestChannel      String?    @map("request_channel") @db.VarChar(50)
  submittedByType     String?    @map("submitted_by_type") @db.VarChar(20)
  city                String?    @db.VarChar(100)
  companyName         String?    @map("company_name") @db.VarChar(100)
  contactName         String     @map("contact_name") @db.VarChar(50)
  contactPhone        String     @map("contact_phone") @db.VarChar(20)
  email               String?    @db.VarChar(100)
  details             Json?
  status              String?    @default("PENDING") @db.VarChar(20)
  assignedAdminUserId String?    @map("assigned_admin_user_id") @db.Uuid
  processedAt         DateTime?  @map("processed_at") @db.Timestamptz(6)
  closedAt            DateTime?  @map("closed_at") @db.Timestamptz(6)
  resolutionResult    String?    @map("resolution_result")
  adminNotes          String?    @map("admin_notes")
  createdAt           DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?  @default(now()) @map("updated_at") @db.Timestamptz(6)
  assignedAdmin       AdminUser? @relation(fields: [assignedAdminUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("partner_applications")
}

model ServiceRequest {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNo         String     @unique @map("reference_no") @db.VarChar(50)
  type                String     @db.VarChar(30)
  requestChannel      String?    @map("request_channel") @db.VarChar(50)
  submittedByType     String?    @map("submitted_by_type") @db.VarChar(20)
  userId              String?    @map("user_id") @db.Uuid
  city                String?    @db.VarChar(100)
  priority            String?    @default("NORMAL") @db.VarChar(20)
  hotelId             String?    @map("hotel_id") @db.Uuid
  roomTypeId          String?    @map("room_type_id") @db.Uuid
  contactName         String     @map("contact_name") @db.VarChar(50)
  contactPhone        String     @map("contact_phone") @db.VarChar(20)
  requestData         Json       @map("request_data")
  status              String?    @default("PENDING") @db.VarChar(20)
  assignedAdminUserId String?    @map("assigned_admin_user_id") @db.Uuid
  processedAt         DateTime?  @map("processed_at") @db.Timestamptz(6)
  closedAt            DateTime?  @map("closed_at") @db.Timestamptz(6)
  adminNotes          String?    @map("admin_notes")
  createdAt           DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?  @default(now()) @map("updated_at") @db.Timestamptz(6)
  assignedAdmin       AdminUser? @relation(fields: [assignedAdminUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hotel               Hotel?     @relation(fields: [hotelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roomType            RoomType?  @relation(fields: [roomTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                User?      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status, city], map: "idx_svc_req_status")
  @@map("service_requests")
}

model Banner {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String?   @db.VarChar(100)
  imageUrl  String    @map("image_url") @db.VarChar(255)
  linkUrl   String?   @map("link_url") @db.VarChar(255)
  position  String    @db.VarChar(50)
  sortOrder Int?      @default(0) @map("sort_order")
  isActive  Boolean?  @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("banners")
}

model MerchantUser {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId   String    @map("merchant_id") @db.Uuid
  email        String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(50)
  role         String    @default("OWNER") @db.VarChar(50)
  status       String?   @default("ACTIVE") @db.VarChar(20)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  merchant     Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("merchant_users")
}

model HotelUser {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId      String    @map("hotel_id") @db.Uuid
  email        String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(50)
  role         String    @default("OWNER") @db.VarChar(50)
  status       String?   @default("ACTIVE") @db.VarChar(20)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  hotel        Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@map("hotel_users")
}
